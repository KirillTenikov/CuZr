FROM kseina89/cuzr-train:qudata-v1

SHELL ["/bin/bash", "-lc"]

# Experimental MACE image with cuEquivariance for CUDA 13.x hosts.
# Keep your stable image unchanged; use this only for short MACE-C benchmarks first.

ARG CUEQ_VERSION=0.9.1

RUN /opt/venv/bin/python -m pip install --upgrade pip setuptools wheel && \
    /opt/venv/bin/python -m pip install \
      "cuequivariance==${CUEQ_VERSION}" \
      "cuequivariance-torch==${CUEQ_VERSION}" \
      "cuequivariance-ops-torch-cu13==${CUEQ_VERSION}" && \
    /opt/venv/bin/python - <<'PY'
import torch
print('torch', torch.__version__)
print('cuda available', torch.cuda.is_available())
import cuequivariance
import cuequivariance_torch
import cuequivariance_ops_torch
print('cuEquivariance imports OK')
PY

CMD ["/bin/bash"]
